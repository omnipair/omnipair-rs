{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.fork-lab-api",
    "watchPatterns": [
      "Dockerfile.fork-lab-api",
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      "railway/fork-api.json",
      "scripts/fork-lab/api.ts",
      "scripts/fork-lab/idl/**"
    ]
  },
  "deploy": {
    "startCommand": "node dist/fork-lab/api.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
