{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      ".dockerignore",
      "Dockerfile",
      "Anchor.toml",
      "Cargo.toml",
      "Cargo.lock",
      "package.json",
      "package-lock.json",
      "railway/surfpool-rpc.json",
      "programs/**",
      "scripts/fork-lab/start_surfpool.sh"
    ]
  },
  "deploy": {
    "startCommand": "npm run fork-lab:surfpool",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
