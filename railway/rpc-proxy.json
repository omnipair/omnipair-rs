{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.fork-lab-rpc-proxy",
    "watchPatterns": [
      "Dockerfile.fork-lab-rpc-proxy",
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      "railway/rpc-proxy.json",
      "scripts/fork-lab/rpc_proxy.ts"
    ]
  },
  "deploy": {
    "startCommand": "npm run fork-lab:rpc-proxy",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
