FROM node:20.19-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json tsconfig.json ./
RUN npm ci --include=dev

COPY scripts/fork-lab ./scripts/fork-lab

RUN node -e "const { Keypair } = require('@solana/web3.js'); const fs = require('fs'); fs.writeFileSync('/app/deployer-keypair.json', JSON.stringify(Array.from(Keypair.generate().secretKey)))"

EXPOSE 3011

CMD ["npm", "run", "fork-lab:api"]
